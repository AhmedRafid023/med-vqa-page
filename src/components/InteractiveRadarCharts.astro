  const modelColors = {
    "Gemini 2.5 Flash": "rgba(56, 189, 248", // cyan-400
    "GPT-4.1 Mini": "rgba(59, 130, 246", // blue-500
    "Claude Sonnet 4": "rgba(250, 204, 21", // yellow-400
    "Llama-3.2V 11B": "rgba(168, 85, 247", // purple-500
    "Gemma-3 12B": "rgba(236, 72, 153", // pink-500
    "Qwen2.5-VL 7B": "rgba(249, 115, 22", // orange-500
    "LLaVA-1.5 7B": "rgba(161, 161, 170", // zinc-400
    "Med-LLaVa 7B": "rgba(16, 185, 129", // emerald-500
    "Med-Gemma 4B": "rgba(239, 68, 68" // red-500
  };

  document.addEventListener('DOMContentLoaded', () => {
    // Shared chart styling config mapped directly from OS system toggles
    const getThemeColors = () => {
      const isDark = document.documentElement.classList.contains('dark') || document.documentElement.getAttribute('data-theme') === 'dark';
      return {
        textColor: isDark ? '#e4e4e7' : '#3f3f46',
        gridColor: isDark ? '#3f3f46' : '#e4e4e7',
        angleLines: isDark ? '#52525b' : '#d4d4d8',
      };
    };

    const buildDatasets = (dataSubset) => {
      return Object.keys(dataSubset).map((model, index) => {
        const color = modelColors[model] || "rgba(100, 100, 100";
        return {
          label: model,
          data: dataSubset[model],
          backgroundColor: `${color}, 0.1)`,
          borderColor: `${color}, 0.8)`,
          borderWidth: 2,
          pointBackgroundColor: `${color}, 1)`,
          pointBorderColor: '#fff',
          pointHoverBackgroundColor: '#fff',
          pointHoverBorderColor: `${color}, 1)`,
          hidden: false
        };
      });
    };

    const commonOptions = (colors) => ({
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: colors.textColor, font: { family: 'inherit', size: 10 }, usePointStyle: true }, position: 'top' },
        tooltip: { bodyFont: { family: 'inherit' }, titleFont: { family: 'inherit' } }
      },
      scales: {
        r: {
          angleLines: { color: colors.angleLines },
          grid: { color: colors.gridColor },
          pointLabels: { color: colors.textColor, font: { family: 'inherit', size: 11 } },
          ticks: { display: false, min: 0, max: 100, stepSize: 20 }
        }
      }
    });

    const categories = ['Modality', 'Organ', 'Abnormality', 'Condition', 'Position'];
    let themeColors = getThemeColors();

    const chartZeroShot = new Chart(document.getElementById('radarZeroShot'), {
      type: 'radar',
      data: { labels: categories, datasets: buildDatasets(radarData.bangla.zeroShot) },
      options: commonOptions(themeColors)
    });

    const chartCoT = new Chart(document.getElementById('radarCoT'), {
      type: 'radar',
      data: { labels: categories, datasets: buildDatasets(radarData.bangla.cot) },
      options: commonOptions(themeColors)
    });

    const chartLoRA = new Chart(document.getElementById('radarLoRA'), {
      type: 'radar',
      data: { labels: categories, datasets: buildDatasets(radarData.bangla.lora) },
      options: commonOptions(themeColors)
    });

    const charts = [chartZeroShot, chartCoT, chartLoRA];

    // Listen to Dataset generic dropdown toggler
    document.getElementById('radar-dataset-selector').addEventListener('change', (e) => {
      const db = e.target.value === 'bangla' ? radarData.bangla : radarData.english;
      chartZeroShot.data.datasets = buildDatasets(db.zeroShot);
      chartCoT.data.datasets = buildDatasets(db.cot);
      chartLoRA.data.datasets = buildDatasets(db.lora);
      charts.forEach(c => c.update());
    });

    // Dark Mode Observer Listener
    const observer = new MutationObserver(() => {
      themeColors = getThemeColors();
      charts.forEach(chart => {
        chart.options.plugins.legend.labels.color = themeColors.textColor;
        chart.options.scales.r.pointLabels.color = themeColors.textColor;
        chart.options.scales.r.grid.color = themeColors.gridColor;
        chart.options.scales.r.angleLines.color = themeColors.angleLines;
        chart.update();
      });
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme'] });
  });
</script>
