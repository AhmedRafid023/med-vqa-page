---
import type { Note } from "../types/types";

interface Props {
  notes: Note[];
}

const { notes } = Astro.props;

const institutions = notes.filter(n => n.symbol.match(/[0-9]/));
const contributions = notes.filter(n => !n.symbol.match(/[0-9]/));
---

<div class="not-prose text-center text-sm text-zinc-500 dark:text-zinc-400 flex flex-col gap-1.5 items-center">
  {institutions.length > 0 && (
    <div class="flex flex-wrap justify-center gap-x-4 gap-y-1">
      {institutions.map((note) => (
        <span>
          <sup class="font-semibold text-zinc-600 dark:text-zinc-300">{note.symbol}</sup>{note.text}
        </span>
      ))}
    </div>
  )}
  {contributions.length > 0 && (
    <div class="flex flex-wrap justify-center gap-x-4 gap-y-1 italic">
      {contributions.map((note) => (
        <span>
          <sup class="font-semibold not-italic text-zinc-600 dark:text-zinc-300">{note.symbol}</sup>{note.text}
        </span>
      ))}
    </div>
  )}
</div>
