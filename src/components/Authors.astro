---
import type { Author } from "../types/types";

interface Props {
  authors: Author[];
}

const { authors } = Astro.props;
---

<div class="not-prose flex flex-row flex-wrap justify-center gap-x-6 gap-y-3">
  {
    authors.map((author) => (
      <div class="flex flex-col items-center text-center">
        <div class="flex flex-row items-start text-lg font-medium text-zinc-800 dark:text-zinc-200">
          {author.url ? (
            <a
              href={author.url}
              class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors no-underline"
            >
              {author.name}
            </a>
          ) : (
            author.name
          )}
          {author.notes && (
            <sup class="text-sm font-normal text-zinc-500 dark:text-zinc-400 ml-0.5">
              {author.notes.map(
                (note, index, array) =>
                  note + (index < array.length - 1 ? "," : ""),
              )}
            </sup>
          )}
        </div>
        {author.institution && (
          <div class="text-sm text-zinc-500 dark:text-zinc-400">
            {author.institution}
          </div>
        )}
      </div>
    ))
  }
</div>
