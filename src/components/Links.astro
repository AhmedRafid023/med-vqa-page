---
import { Icon } from "astro-icon/components";
import type { Link } from "../types/types";

interface Props {
  links: Link[];
}

const { links } = Astro.props;
---

<div class="not-prose flex flex-row flex-wrap justify-center gap-3">
  {
    links.map((link) => (
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-row items-center gap-2 rounded-full bg-zinc-900 dark:bg-zinc-100 px-6 py-2.5 text-base font-medium text-white dark:text-zinc-900 shadow-sm hover:bg-zinc-700 dark:hover:bg-white hover:shadow-md transition-all duration-150 no-underline active:scale-95"
      >
        {link.icon && (
          <Icon
            name={link.icon}
            class="text-lg shrink-0 opacity-90 group-hover:opacity-100"
          />
        )}
        <span>{link.name}</span>
      </a>
    ))
  }
</div>
