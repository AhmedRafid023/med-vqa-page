---
<div class="my-10 w-full rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 shadow-sm p-6">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h3 class="text-xl font-bold m-0 leading-none">Interactive Model Comparison (Overall LAVE)</h3>
    <div class="relative">
      <select id="dataset-selector" class="appearance-none w-full pl-4 pr-10 py-2 bg-zinc-100 dark:bg-zinc-800 border border-zinc-300 dark:border-zinc-700 rounded-lg text-sm cursor-pointer outline-none focus:ring-2 focus:ring-blue-500 font-medium text-zinc-800 dark:text-zinc-200">
        <option value="bangla">Bangla QA Pairs</option>
        <option value="english">English QA Pairs</option>
      </select>
      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-zinc-500 dark:text-zinc-400">
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </div>
    </div>
  </div>
  <div class="relative w-full h-[400px]">
    <canvas id="modelChart"></canvas>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline>
  const dataBangla = {
    labels: ['Gemini 2.5 Flash', 'GPT-4.1 Mini', 'Claude Sonnet 4', 'Llama-3.2V 11B', 'Gemma-3 12B', 'Qwen2.5-VL 7B', 'LLaVA-1.5 7B', 'Med-LLaVa 7B', 'Med-Gemma 4B'],
    datasets: [
      { label: 'Zero-Shot', data: [55.44, 38.60, 45.28, 25.50, 46.54, 35.58, 16.98, 21.71, 19.85], backgroundColor: '#38bdf8' },
      { label: 'CoT Prompt', data: [54.96, 35.93, 47.62, 38.68, 48.67, 34.50, 5.30, 23.33, 28.57], backgroundColor: '#818cf8' },
      { label: 'LoRA Fine-Tuning', data: [null, null, null, 66.74, 65.03, 67.18, 61.44, 61.98, 69.95], backgroundColor: '#c084fc' }
    ]
  };

  const dataEnglish = {
    labels: ['Gemini 2.5 Flash', 'GPT-4.1 Mini', 'Claude Sonnet 4', 'Llama-3.2V 11B', 'Gemma-3 12B', 'Qwen2.5-VL 7B', 'LLaVA-1.5 7B', 'Med-LLaVa 7B', 'Med-Gemma 4B'],
    datasets: [
      { label: 'Zero-Shot', data: [57.81, 53.01, 54.69, 49.28, 50.45, 56.48, 35.45, 36.25, 28.35], backgroundColor: '#38bdf8' },
      { label: 'CoT Prompt', data: [57.65, 52.58, 53.18, 50.19, 51.03, 55.53, 37.45, 35.25, 27.54], backgroundColor: '#818cf8' },
      { label: 'LoRA Fine-Tuning', data: [null, null, null, 76.45, 70.40, 71.30, 68.04, 66.44, 75.99], backgroundColor: '#c084fc' }
    ]
  };

  document.addEventListener('DOMContentLoaded', () => {
    const ctx = document.getElementById('modelChart').getContext('2d');
    
    const getColors = () => {
      const isDarkMode = document.documentElement.classList.contains('dark') || document.documentElement.getAttribute('data-theme') === 'dark';
      return {
        textColor: isDarkMode ? '#e4e4e7' : '#3f3f46',
        gridColor: isDarkMode ? '#27272a' : '#e4e4e7'
      };
    };

    let colors = getColors();

    let chart = new Chart(ctx, {
      type: 'bar',
      data: dataBangla,
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: colors.textColor, font: { family: 'inherit' } }, position: 'top' },
          tooltip: { mode: 'index', intersect: false, bodyFont: { family: 'inherit' }, titleFont: { family: 'inherit' } }
        },
        scales: {
          x: { 
            ticks: { color: colors.textColor, maxRotation: 45, minRotation: 45, font: { family: 'inherit' } }, 
            grid: { color: colors.gridColor, drawBorder: false } 
          },
          y: { 
            ticks: { color: colors.textColor, font: { family: 'inherit' } }, 
            grid: { color: colors.gridColor, drawBorder: false }, 
            beginAtZero: true,
            max: 100
          }
        }
      }
    });

    document.getElementById('dataset-selector').addEventListener('change', (e) => {
      chart.data = e.target.value === 'bangla' ? dataBangla : dataEnglish;
      chart.update();
    });

    // Handle dark mode toggling dynamically
    const observer = new MutationObserver(() => {
      let newColors = getColors();
      chart.options.plugins.legend.labels.color = newColors.textColor;
      chart.options.scales.x.ticks.color = newColors.textColor;
      chart.options.scales.x.grid.color = newColors.gridColor;
      chart.options.scales.y.ticks.color = newColors.textColor;
      chart.options.scales.y.grid.color = newColors.gridColor;
      chart.update();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme'] });
  });
</script>
